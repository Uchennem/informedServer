---
export const prerender = false;

import { buildServerApiUrl } from '../../lib/api';
const request = Astro.request;

try {
  const response = await fetch(buildServerApiUrl('/api/users', Astro.url), {
    headers: {
      cookie: request.headers.get('cookie') ?? '',
    },
  });

  if (response.ok) {
    const payload = await response.json();
    const currentUser = payload?.user ?? payload;
    const userId = currentUser?.id ?? currentUser?._id;

    if (userId) {
      return Astro.redirect(`/profile/${userId}`);
    }
  }
} catch {
  // fall through to feed redirect
}

return Astro.redirect('/feed');
---
