---
import Layout from '../../layouts/Layout.astro';

export const prerender = false;

type UserProfile = {
  id?: string;
  _id?: string;
  name?: string;
  major?: string;
  year?: string | number;
  bio?: string;
  avatar?: string;
  interestTags?: string[];
  interests?: string[];
};

type Post = {
  id?: string;
  _id?: string;
  title?: string;
  category?: string;
  date?: string;
  createdAt?: string;
};

const { id } = Astro.params;
const baseUrl = import.meta.env.PUBLIC_API_BASE_URL;
const request = Astro.request;
const cookieHeader = request.headers.get('cookie') ?? '';

let user: UserProfile | null = null;
let recentPosts: Post[] = [];
let isOwnProfile = false;
let isNotFound = false;

function normalizeUser(payload: unknown): UserProfile | null {
  if (!payload || typeof payload !== 'object') {
    return null;
  }

  const candidate = payload as Record<string, unknown>;

  if (candidate.user && typeof candidate.user === 'object') {
    return candidate.user as UserProfile;
  }

  if ('name' in candidate || 'id' in candidate || '_id' in candidate) {
    return candidate as UserProfile;
  }

  return null;
}

if (!id || !baseUrl) {
  isNotFound = true;
  Astro.response.status = 404;
} else {
  try {
    const userResponse = await fetch(import.meta.env.PUBLIC_API_BASE_URL + '/api/users/' + id, {
      headers: {
        cookie: cookieHeader,
      },
    });

    if (userResponse.status === 404) {
      isNotFound = true;
      Astro.response.status = 404;
    } else if (userResponse.ok) {
      const userPayload = await userResponse.json();
      user = normalizeUser(userPayload);

      if (!user) {
        isNotFound = true;
        Astro.response.status = 404;
      }
    } else {
      isNotFound = true;
      Astro.response.status = userResponse.status;
    }
  } catch {
    isNotFound = true;
    Astro.response.status = 404;
  }

  if (!isNotFound) {
    try {
      const postsResponse = await fetch(`${baseUrl}/api/posts?author=${encodeURIComponent(id)}`, {
        headers: {
          cookie: cookieHeader,
        },
      });

      if (postsResponse.ok) {
        const postsPayload = await postsResponse.json();
        recentPosts = Array.isArray(postsPayload)
          ? postsPayload
          : Array.isArray(postsPayload?.posts)
            ? postsPayload.posts
            : [];
      }
    } catch {
      recentPosts = [];
    }

    try {
      const currentUserResponse = await fetch(`${baseUrl}/api/users`, {
        headers: {
          cookie: cookieHeader,
        },
      });

      if (currentUserResponse.ok) {
        const currentUserPayload = await currentUserResponse.json();
        const currentUser = normalizeUser(currentUserPayload);

        const currentUserId = currentUser?.id ?? currentUser?._id;
        const profileUserId = user?.id ?? user?._id;

        isOwnProfile = Boolean(currentUserId && profileUserId && currentUserId === profileUserId);
      }
    } catch {
      isOwnProfile = false;
    }
  }
}

const interestTags = user?.interestTags ?? user?.interests ?? [];
---

<Layout>
  <main class="min-h-screen bg-slate-900 text-slate-200">
    <div class="max-w-2xl mx-auto px-4 py-8">
      {
        isNotFound || !user ? (
          <section class="card text-center py-12">
            <h1 class="text-2xl font-bold mb-4">User not found</h1>
            <p class="text-slate-400">This profile may not exist or is unavailable right now.</p>
          </section>
        ) : (
          <>
            {/* Profile Header */}
            <section class="card mb-6 flex gap-6 items-start">
              <img
                src={user.avatar || '/favicon.svg'}
                alt={user.name ? `${user.name}'s avatar` : 'User avatar'}
                class="avatar-lg flex-shrink-0"
              />

              <div class="flex-1">
                <h1 class="text-3xl font-bold mb-2">{user.name ?? 'Unnamed User'}</h1>
                <p class="text-slate-400 mb-4 flex gap-2 text-sm">
                  <span class="font-medium">{user.major ?? 'Undeclared Major'}</span>
                  <span>•</span>
                  <span>{user.year ?? 'Year not provided'}</span>
                </p>

                {isOwnProfile ? (
                  <button type="button" class="btn-primary text-sm">
                    Edit Profile
                  </button>
                ) : null}
              </div>
            </section>

            {/* Bio Section */}
            <section class="card mb-6">
              <h2 class="text-xl font-bold mb-3">Bio</h2>
              <p class="text-slate-300">{user.bio ?? 'No bio available.'}</p>
            </section>

            {/* Interests Section */}
            <section class="card mb-6">
              <h2 class="text-xl font-bold mb-3">Interest Tags</h2>
              {interestTags.length > 0 ? (
                <ul class="flex flex-wrap gap-2">
                  {interestTags.map((tag) => (
                    <li class="badge badge-academic text-xs">{tag}</li>
                  ))}
                </ul>
              ) : (
                <p class="text-slate-400 text-sm">No interests shared yet.</p>
              )}
            </section>

            {/* Recent Posts Section */}
            <section class="card mb-6">
              <h2 class="text-xl font-bold mb-4">Recent Posts</h2>
              {recentPosts.length > 0 ? (
                <ul class="space-y-3">
                  {recentPosts.map((post, index) => (
                    <li class={`${index > 0 ? 'pt-3 border-t border-slate-600' : ''}`}>
                      <p class="font-semibold text-slate-100 mb-1">{post.title ?? 'Untitled Post'}</p>
                      <p class="text-slate-400 text-sm flex gap-2">
                        <span class="badge badge-social text-xs">{post.category ?? 'General'}</span>
                        <time datetime={post.date ?? post.createdAt ?? ''}>
                          {post.date || post.createdAt
                            ? new Date(post.date ?? post.createdAt ?? '').toLocaleDateString()
                            : 'Date unavailable'}
                        </time>
                      </p>
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="text-slate-400 text-sm">No recent posts found.</p>
              )}
            </section>
          </>
        )
      }
    </div>
  </main>
</Layout>
