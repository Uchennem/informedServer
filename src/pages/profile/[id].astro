---
import Layout from '../../layouts/Layout.astro';

export const prerender = false;

type UserProfile = {
  id?: string;
  _id?: string;
  name?: string;
  major?: string;
  year?: string | number;
  bio?: string;
  avatar?: string;
  interestTags?: string[];
  interests?: string[];
};

type Post = {
  id?: string;
  _id?: string;
  title?: string;
  category?: string;
  date?: string;
  createdAt?: string;
};

const { id } = Astro.params;
const baseUrl = import.meta.env.PUBLIC_API_BASE_URL;
const request = Astro.request;
const cookieHeader = request.headers.get('cookie') ?? '';

let user: UserProfile | null = null;
let recentPosts: Post[] = [];
let isOwnProfile = false;
let isNotFound = false;

function normalizeUser(payload: unknown): UserProfile | null {
  if (!payload || typeof payload !== 'object') {
    return null;
  }

  const candidate = payload as Record<string, unknown>;

  if (candidate.user && typeof candidate.user === 'object') {
    return candidate.user as UserProfile;
  }

  if ('name' in candidate || 'id' in candidate || '_id' in candidate) {
    return candidate as UserProfile;
  }

  return null;
}

if (!id || !baseUrl) {
  isNotFound = true;
  Astro.response.status = 404;
} else {
  try {
    const userResponse = await fetch(import.meta.env.PUBLIC_API_BASE_URL + '/api/users/' + id, {
      headers: {
        cookie: cookieHeader,
      },
    });

    if (userResponse.status === 404) {
      isNotFound = true;
      Astro.response.status = 404;
    } else if (userResponse.ok) {
      const userPayload = await userResponse.json();
      user = normalizeUser(userPayload);

      if (!user) {
        isNotFound = true;
        Astro.response.status = 404;
      }
    } else {
      isNotFound = true;
      Astro.response.status = userResponse.status;
    }
  } catch {
    isNotFound = true;
    Astro.response.status = 404;
  }

  if (!isNotFound) {
    try {
      const postsResponse = await fetch(`${baseUrl}/api/posts?author=${encodeURIComponent(id)}`, {
        headers: {
          cookie: cookieHeader,
        },
      });

      if (postsResponse.ok) {
        const postsPayload = await postsResponse.json();
        recentPosts = Array.isArray(postsPayload)
          ? postsPayload
          : Array.isArray(postsPayload?.posts)
            ? postsPayload.posts
            : [];
      }
    } catch {
      recentPosts = [];
    }

    try {
      const currentUserResponse = await fetch(`${baseUrl}/api/users`, {
        headers: {
          cookie: cookieHeader,
        },
      });

      if (currentUserResponse.ok) {
        const currentUserPayload = await currentUserResponse.json();
        const currentUser = normalizeUser(currentUserPayload);

        const currentUserId = currentUser?.id ?? currentUser?._id;
        const profileUserId = user?.id ?? user?._id;

        isOwnProfile = Boolean(currentUserId && profileUserId && currentUserId === profileUserId);
      }
    } catch {
      isOwnProfile = false;
    }
  }
}

const interestTags = user?.interestTags ?? user?.interests ?? [];
---

<Layout>
  <main class="min-h-screen pb-20 md:pb-8">
    <div class="max-w-4xl mx-auto px-4 py-6 md:py-8">
      {
        isNotFound || !user ? (
          <section class="card text-center py-16 border-2 border-dashed border-slate-600">
            <svg class="w-12 h-12 mx-auto text-slate-500 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-2a6 6 0 0112 0v2zm0 0h6v-2a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
            <h1 class="text-2xl font-bold text-slate-100 mb-2">User not found</h1>
            <p class="text-slate-400">This profile may not exist or is unavailable right now.</p>
            <a href="/people" class="btn-primary mt-6 inline-block">Back to people</a>
          </section>
        ) : (
          <>
            {/* Profile Hero Section */}
            <section class="card overflow-hidden mb-8 relative">
              {/* Decorative signal beams */}
              <div class="absolute inset-0 opacity-30 -z-10">
                <div class="absolute top-0 right-0 w-72 h-72 bg-gradient-to-bl from-nc-accent-primary via-transparent to-transparent rounded-full blur-3xl opacity-20"></div>
              </div>

              <div class="relative z-10 p-8 md:p-12">
                <div class="flex flex-col md:flex-row gap-6 md:gap-8 items-start md:items-center mb-8">
                  {/* Avatar */}
                  <div class="relative flex-shrink-0">
                    <div class="w-24 h-24 md:w-32 md:h-32 rounded-full bg-gradient-to-br from-nc-accent-primary to-nc-accent-secondary flex items-center justify-center text-5xl font-bold text-white overflow-hidden">
                      {user.avatar ? (
                        <img src={user.avatar} alt={user.name || 'Avatar'} class="w-full h-full object-cover" />
                      ) : (
                        (user.name?.[0] ?? '?').toUpperCase()
                      )}
                    </div>
                    <div class="absolute -bottom-2 -right-2 w-6 h-6 bg-nc-success rounded-full border-2 border-nc-bg-card"></div>
                  </div>

                  {/* Profile Info */}
                  <div class="flex-1">
                    <h1 class="text-4xl md:text-5xl font-bold text-slate-100 font-display uppercase tracking-wider mb-2">
                      {user.name ?? 'Unnamed User'}
                    </h1>
                    <p class="text-slate-400 text-lg mb-4 flex flex-wrap gap-2">
                      <span class="chip text-sm bg-nc-accent-primary/20 text-nc-accent-primary">
                        {user.major ?? 'Undeclared'}
                      </span>
                      {user.year && (
                        <span class="chip text-sm bg-nc-accent-secondary/20 text-nc-accent-secondary">
                          Class of {user.year}
                        </span>
                      )}
                    </p>

                    {isOwnProfile && (
                      <button type="button" class="btn-primary">
                        Edit Profile
                      </button>
                    )}
                  </div>
                </div>

                {/* Bio */}
                {user.bio && (
                  <div class="pt-6 border-t border-slate-700/50">
                    <p class="text-slate-300 text-base leading-relaxed italic">{user.bio}</p>
                  </div>
                )}
              </div>
            </section>

            {/* Interests Section */}
            {interestTags.length > 0 && (
              <section class="card mb-8">
                <h2 class="text-2xl font-bold text-slate-100 font-display uppercase tracking-wide mb-4 flex items-center gap-3">
                  <div class="w-1 h-8 bg-gradient-to-b from-nc-accent-primary to-nc-accent-secondary rounded-full"></div>
                  Interests
                </h2>
                <div class="flex flex-wrap gap-2">
                  {interestTags.map((tag) => (
                    <span class="chip text-sm bg-nc-accent-primary/20 text-nc-accent-primary border border-nc-accent-primary/30">
                      {tag}
                    </span>
                  ))}
                </div>
              </section>
            )}

            {/* Recent Posts Section */}
            {recentPosts.length > 0 && (
              <section class="card">
                <h2 class="text-2xl font-bold text-slate-100 font-display uppercase tracking-wide mb-4 flex items-center gap-3">
                  <div class="w-1 h-8 bg-gradient-to-b from-nc-accent-secondary to-nc-accent-primary rounded-full"></div>
                  Recent Posts
                </h2>
                <div class="space-y-3">
                  {recentPosts.map((post, index) => (
                    <div class={`${index > 0 ? 'pt-3 border-t border-slate-700/50' : ''}`}>
                      <h3 class="font-bold text-slate-100 mb-1 uppercase tracking-wide">{post.title ?? 'Untitled Post'}</h3>
                      <p class="text-slate-400 text-sm flex gap-2 items-center flex-wrap">
                        <span class="chip text-xs bg-blue-500/20 text-blue-300">
                          {post.category ?? 'General'}
                        </span>
                        <time datetime={post.date ?? post.createdAt ?? ''} class="text-slate-500">
                          {post.date || post.createdAt
                            ? new Date(post.date ?? post.createdAt ?? '').toLocaleDateString('en-US', { 
                                year: 'numeric', 
                                month: 'short', 
                                day: 'numeric' 
                              })
                            : 'Date unavailable'}
                        </time>
                      </p>
                    </div>
                  ))}
                </div>
              </section>
            )}

            {recentPosts.length === 0 &&  !interestTags.length && !user.bio && (
              <section class="card text-center py-12">
                <svg class="w-12 h-12 mx-auto text-slate-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4"/>
                </svg>
                <p class="text-slate-400">This profile is just getting started</p>
              </section>
            )}
          </>
        )
      }
    </div>
  </main>
</Layout>
