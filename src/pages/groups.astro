---
import GroupCard from '../components/GroupCard.astro';
import JoinButton from '../components/JoinButton.svelte';
import Layout from '../layouts/Layout.astro';
import { buildServerApiUrl } from '../lib/api';

type Group = {
  id: string;
  _id?: string;
  name: string;
  description?: string;
  category?: string;
  memberCount?: number;
  isMember?: boolean;
};

let groups: Group[] = [];

const authCookieHeader = Astro.request.headers.get('cookie') ?? '';

if (!authCookieHeader.includes('better-auth.session_token')) {
  return Astro.redirect('/login');
}

try {
  const response = await fetch(buildServerApiUrl('/api/groups', Astro.url), {
    headers: {
      cookie: authCookieHeader,
    },
  });

  if (response.ok) {
    const data = await response.json();
    groups = Array.isArray(data) ? data : [];
  }
} catch {
  groups = [];
}

const myGroups = groups.filter((group) => group.isMember);
---

<Layout>
  <main class="min-h-screen pb-20 md:pb-8">
    <div class="max-w-7xl mx-auto px-4 py-6 md:py-8">
      {/* Header */}
      <div class="mb-12">
        <h1 class="text-5xl font-bold text-slate-100 font-display uppercase tracking-wider mb-2">Student Organizations</h1>
        <p class="text-slate-400 text-lg">Find your community and join groups that match your interests</p>
      </div>

      {/* My Groups Section */}
      {myGroups.length > 0 && (
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-slate-100 font-display uppercase tracking-wide mb-4 flex items-center gap-3">
            <div class="w-1 h-8 bg-gradient-to-b from-nc-accent-primary to-nc-accent-secondary rounded-full"></div>
            My Groups
          </h2>
          <div class="overflow-x-auto pb-2">
            <div class="flex gap-3 min-w-max">
              {myGroups.map((group) => (
                <div class="chip bg-nc-accent-primary/15 text-nc-accent-primary border border-nc-accent-primary/30 text-sm font-semibold flex-shrink-0 hover:bg-nc-accent-primary/25 transition-all">
                  ✓ {group.name}
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      {/* Discover Groups Section */}
      <section>
        <h2 class="text-2xl font-bold text-slate-100 font-display uppercase tracking-wide mb-6 flex items-center gap-3">
          <div class="w-1 h-8 bg-gradient-to-b from-nc-accent-secondary to-nc-accent-primary rounded-full"></div>
          Discover Groups
        </h2>

        {
          groups.length > 0 ? (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-container">
              {groups.map((group) => {
                const groupId = group.id ?? group._id ?? '';
                return (
                  <GroupCard
                    group={{
                      id: groupId,
                      name: group.name,
                      description: group.description,
                      category: group.category,
                      memberCount: group.memberCount,
                    }}
                  >
                    <JoinButton
                      client:load
                      groupId={groupId}
                      isMember={group.isMember ?? false}
                      memberCount={group.memberCount ?? 0}
                    />
                  </GroupCard>
                );
              })}
            </div>
          ) : (
            <div class="card py-16 text-center border-2 border-dashed border-slate-600">
              <svg class="w-12 h-12 mx-auto text-slate-500 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
              </svg>
              <p class="text-slate-300 font-semibold text-lg">No groups available yet</p>
              <p class="mt-2 text-sm text-slate-400">Check back soon as more groups get created on campus</p>
            </div>
          )
        }
      </section>
    </div>
  </main>
</Layout>