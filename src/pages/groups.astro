---
import GroupCard from '../components/GroupCard.astro';
import JoinButton from '../components/JoinButton.svelte';
import CreateGroupForm from '../components/CreateGroupForm.svelte';
import Layout from '../layouts/Layout.astro';
import { buildServerApiUrl } from '../lib/api';

type Group = {
  id: string;
  _id?: string;
  name: string;
  description?: string;
  category?: string;
  tags?: string[];
  memberCount?: number;
  isMember?: boolean;
};

let groups: Group[] = [];

const authCookieHeader = Astro.request.headers.get('cookie') ?? '';
const groupFilters = ['All', 'Academic', 'Social', 'Sports', 'Faith', 'Arts'];

if (!authCookieHeader.includes('better-auth.session_token')) {
  return Astro.redirect('/login');
}

function normalizeValue(value: string) {
  return value.trim().toLowerCase();
}

function getGroupFilterKeys(group: Group) {
  const values = [
    group.category ?? '',
    ...(Array.isArray(group.tags) ? group.tags : []),
    group.name ?? '',
    group.description ?? '',
  ]
    .flatMap((value) => value.split(/[\s,/]+/))
    .map(normalizeValue)
    .filter(Boolean);

  const keys = new Set(values);

  if (keys.has('creative') || keys.has('art') || keys.has('music') || keys.has('design')) {
    keys.add('arts');
  }

  if (keys.has('study') || keys.has('studies') || keys.has('coding') || keys.has('stem') || keys.has('cs')) {
    keys.add('academic');
  }

  if (keys.has('community') || keys.has('friends') || keys.has('networking')) {
    keys.add('social');
  }

  if (keys.has('fitness') || keys.has('athletics')) {
    keys.add('sports');
  }

  if (keys.has('religion') || keys.has('spiritual')) {
    keys.add('faith');
  }

  return Array.from(keys);
}

try {
  const response = await fetch(buildServerApiUrl('/api/groups', Astro.url), {
    headers: {
      cookie: authCookieHeader,
    },
  });

  if (response.ok) {
    const data = await response.json();
    groups = Array.isArray(data) ? data : [];
  }
} catch {
  groups = [];
}

const myGroups = groups.filter((group) => group.isMember);
---

<Layout>
  <main class="min-h-screen pb-20 md:pb-8">
    <div class="max-w-7xl mx-auto px-4 py-5 sm:py-6 md:py-8">
      {/* Header */}
      <div class="section-header mb-6">
        <span class="section-eyebrow">Campus communities</span>
        <h1>Student Organizations</h1>
        <p class="section-subtitle">Find your community and join groups that match your interests.</p>
      </div>

      <div class="mb-8">
        <CreateGroupForm client:load />
      </div>

      {/* My Groups Strip */}
      {myGroups.length > 0 && (
        <section class="mb-8">
          <h2 class="text-sm font-bold text-nc-text-muted uppercase tracking-wider mb-3">My Groups</h2>
          <div class="overflow-x-auto pb-2 scrollbar-thin">
            <div class="flex gap-2 min-w-max">
              {myGroups.map((group) => (
                <div class="text-xs font-semibold flex-shrink-0 rounded-full px-3 py-1.5 bg-nc-accent-primary/12 text-nc-accent-primary border border-nc-accent-primary/25 hover:bg-nc-accent-primary/20 transition-all cursor-pointer">
                  ✓ {group.name}
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      {/* Category Filters */}
      <div class="mb-6 sticky top-0 bg-gradient-to-b from-nc-bg-root via-nc-bg-root to-nc-bg-root/0 backdrop-blur-sm z-10 pb-3 pt-1">
        <div class="overflow-x-auto scrollbar-thin -mx-1 px-1">
          <div class="flex gap-2 min-w-max" id="groupFilterBar">
            {groupFilters.map((filter) => (
              <button
                type="button"
                class={`chip text-xs font-bold uppercase tracking-wider transition-all duration-200 flex-shrink-0 min-h-9 px-5 ${
                  filter === 'All' ? 'active' : ''
                }`}
                data-filter={filter}
              >
                {filter}
              </button>
            ))}
          </div>
        </div>
      </div>

      {/* Groups Grid */}
      <section>
        {
          groups.length > 0 ? (
            <>
              <div
                id="groupFilterEmptyState"
                class="card py-12 px-6 text-center hidden"
                data-default-message="No groups match this filter yet."
              >
                <svg class="w-10 h-10 mx-auto text-nc-text-subtle mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
                <p class="text-nc-text-primary font-semibold mb-1">No groups match this filter</p>
                <p class="text-sm text-nc-text-muted mb-0" id="groupFilterEmptyMessage">Try a different category or create a new group.</p>
              </div>

              <div class="grid grid-cols-1 gap-4 sm:gap-5 md:grid-cols-2 lg:grid-cols-3 lg:gap-6 stagger-container" id="groupsGrid">
              {groups.map((group) => {
                const groupId = group.id ?? group._id ?? '';
                const filterKeys = getGroupFilterKeys(group).join(' ');
                return (
                  <div data-group-card data-group-filters={filterKeys}>
                    <GroupCard
                      group={{
                        id: groupId,
                        name: group.name,
                        description: group.description,
                        category: group.category,
                        memberCount: group.memberCount,
                        isMember: group.isMember,
                      }}
                    >
                      <JoinButton
                        client:load
                        groupId={groupId}
                        isMember={group.isMember ?? false}
                        memberCount={group.memberCount ?? 0}
                      />
                    </GroupCard>
                  </div>
                );
              })}
              </div>
            </>
          ) : (
            <div class="card py-12 px-6 text-center">
              <svg class="w-10 h-10 mx-auto text-nc-text-subtle mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
              </svg>
              <p class="text-nc-text-primary font-semibold mb-1">No groups available yet</p>
              <p class="text-sm text-nc-text-muted mb-0">Check back soon as more groups get created on campus</p>
            </div>
          )
        }
      </section>
    </div>
  </main>
</Layout>

<script>
  // Group filter interactivity
  const bar = document.getElementById('groupFilterBar');
  const groupCards = Array.from(document.querySelectorAll('[data-group-card]'));
  const emptyState = document.getElementById('groupFilterEmptyState');
  const emptyMessage = document.getElementById('groupFilterEmptyMessage');

  function applyGroupFilter(selectedFilter) {
    let visibleCount = 0;

    groupCards.forEach((card) => {
      const filters = (card.getAttribute('data-group-filters') ?? '').split(/\s+/).filter(Boolean);
      const isVisible = selectedFilter === 'All' || filters.includes(selectedFilter.toLowerCase());

      card.classList.toggle('hidden', !isVisible);

      if (isVisible) {
        visibleCount += 1;
      }
    });

    if (emptyState) {
      emptyState.classList.toggle('hidden', visibleCount > 0 || groupCards.length === 0);
    }

    if (emptyMessage) {
      emptyMessage.textContent = selectedFilter === 'All'
        ? 'Try a different category or create a new group.'
        : `No ${selectedFilter.toLowerCase()} groups match right now.`;
    }
  }

  if (bar) {
    bar.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button');
      if (!btn) return;
      bar.querySelectorAll('button').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      applyGroupFilter(btn.dataset.filter ?? 'All');
    });
  }

  applyGroupFilter('All');

  window.addEventListener('informed:group-created', () => {
    window.location.reload();
  });
</script>
