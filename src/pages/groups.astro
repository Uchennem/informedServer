---
import GroupCard from '../components/GroupCard.astro';
import JoinButton from '../components/JoinButton.svelte';
import Layout from '../layouts/Layout.astro';

type Group = {
  id: string;
  _id?: string;
  name: string;
  description?: string;
  category?: string;
  memberCount?: number;
  isMember?: boolean;
};

let groups: Group[] = [];

try {
  const response = await fetch(import.meta.env.PUBLIC_API_BASE_URL + '/api/groups');

  if (response.ok) {
    const data = await response.json();
    groups = Array.isArray(data) ? data : [];
  }
} catch {
  groups = [];
}
---

<Layout>
  <main class="groups-page">
    <h1>Groups</h1>

    {
      groups.length > 0 ? (
        groups.map((group) => {
          const groupId = group.id ?? group._id ?? '';
          return (
            <GroupCard
              group={{
                id: groupId,
                name: group.name,
                description: group.description,
                category: group.category,
                memberCount: group.memberCount,
              }}
            >
              <JoinButton
                client:load
                groupId={groupId}
                isMember={group.isMember ?? false}
                memberCount={group.memberCount ?? 0}
              />
            </GroupCard>
          );
        })
      ) : (
        <p>No groups available.</p>
      )
    }
  </main>
</Layout>

<style>
  .groups-page {
    max-width: 860px;
    margin: 2rem auto;
    padding: 0 1rem;
  }

  h1 {
    margin: 0 0 1rem;
  }
</style>