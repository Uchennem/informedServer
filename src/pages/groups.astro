---
import GroupCard from '../components/GroupCard.astro';
import JoinButton from '../components/JoinButton.svelte';
import Layout from '../layouts/Layout.astro';
import { buildServerApiUrl } from '../lib/api';

type Group = {
  id: string;
  _id?: string;
  name: string;
  description?: string;
  category?: string;
  memberCount?: number;
  isMember?: boolean;
};

let groups: Group[] = [];

const authCookieHeader = Astro.request.headers.get('cookie') ?? '';

if (!authCookieHeader.includes('better-auth.session_token')) {
  return Astro.redirect('/login');
}

try {
  const response = await fetch(buildServerApiUrl('/api/groups', Astro.url), {
    headers: {
      cookie: authCookieHeader,
    },
  });

  if (response.ok) {
    const data = await response.json();
    groups = Array.isArray(data) ? data : [];
  }
} catch {
  groups = [];
}

const myGroups = groups.filter((group) => group.isMember);
---

<Layout>
  <main class="min-h-screen bg-slate-900 pb-20 md:pb-8">
    <div class="max-w-6xl mx-auto px-4 py-6 md:py-8">
      <h1 class="text-3xl font-bold mb-6">Groups</h1>

      <section class="mb-8">
        <h2 class="mb-3 text-lg font-bold text-slate-100">My Groups</h2>
        {myGroups.length > 0 ? (
          <div class="overflow-x-auto">
            <div class="flex min-w-max gap-2">
              {myGroups.map((group) => (
                <span class="badge badge-event text-xs">{group.name}</span>
              ))}
            </div>
          </div>
        ) : (
          <p class="text-sm text-slate-400">Join a group to see it pinned here.</p>
        )}
      </section>

      <section>
        <h2 class="mb-4 text-lg font-bold text-slate-100">Discover Groups</h2>

        {
          groups.length > 0 ? (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {groups.map((group) => {
                const groupId = group.id ?? group._id ?? '';
                return (
                  <GroupCard
                    group={{
                      id: groupId,
                      name: group.name,
                      description: group.description,
                      category: group.category,
                      memberCount: group.memberCount,
                    }}
                  >
                    <JoinButton
                      client:load
                      groupId={groupId}
                      isMember={group.isMember ?? false}
                      memberCount={group.memberCount ?? 0}
                    />
                  </GroupCard>
                );
              })}
            </div>
          ) : (
            <div class="card text-center py-12">
              <p class="text-slate-400">No groups available.</p>
            </div>
          )
        }
      </section>
    </div>
  </main>
</Layout>