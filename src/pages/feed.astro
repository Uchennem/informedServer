---
import PostCard from '../components/PostCard.astro';
import ConnectButton from '../components/ConnectButton.svelte';
import CreatePostForm from '../components/CreatePostForm.svelte';
import Layout from '../layouts/Layout.astro';
import { buildServerApiUrl } from '../lib/api';

type Post = {
  id: string;
  title: string;
  description?: string;
  body?: string;
  author: string;
  category: string;
  rsvpCount: number;
  date: string;
  location?: string;
};

type MatchUser = {
  id?: string;
  _id?: string;
  name: string;
  major?: string;
  sharedInterestTags?: string[];
  sharedInterests?: string[];
};

const request = Astro.request;
const plannerPills = ['Tonight', 'This Week', 'Weekend'];
const feedFilters = ['All', 'Social', 'Academic', 'Sports', 'Faith', 'Arts'];
const authCookieHeader = Astro.request.headers.get('cookie') ?? '';

if (!authCookieHeader.includes('better-auth.session_token')) {
  return Astro.redirect('/login');
}

function normalizeValue(value: string) {
  return value.trim().toLowerCase();
}

function getPostFilterKeys(post: Post) {
  const values = [
    post.category ?? '',
    post.title ?? '',
    post.description ?? '',
    post.body ?? '',
    post.location ?? '',
  ]
    .flatMap((value) => value.split(/[\s,/]+/))
    .map(normalizeValue)
    .filter(Boolean);

  const keys = new Set(values);

  if (keys.has('events') || keys.has('event') || keys.has('networking') || keys.has('social') || keys.has('community')) {
    keys.add('social');
  }

  if (keys.has('workshops') || keys.has('workshop') || keys.has('academic') || keys.has('study') || keys.has('coding')) {
    keys.add('academic');
  }

  if (keys.has('sports') || keys.has('fitness') || keys.has('game') || keys.has('games') || keys.has('athletics')) {
    keys.add('sports');
  }

  if (keys.has('faith') || keys.has('church') || keys.has('ministry') || keys.has('spiritual')) {
    keys.add('faith');
  }

  if (keys.has('arts') || keys.has('art') || keys.has('music') || keys.has('creative') || keys.has('design')) {
    keys.add('arts');
  }

  return Array.from(keys);
}

let posts: Post[] = [];
let matches: MatchUser[] = [];

try {
  const response = await fetch(buildServerApiUrl('/api/posts', Astro.url), {
    headers: {
      cookie: authCookieHeader,
    },
  });

  if (response.ok) {
    const data = await response.json();
    posts = Array.isArray(data) ? data : [];
  }
} catch {
  posts = [];
}

try {
  const response = await fetch(buildServerApiUrl('/api/users/matches', Astro.url), {
    headers: {
      cookie: request.headers.get('cookie') ?? '',
    },
  });

  if (response.ok) {
    const data = await response.json();
    matches = Array.isArray(data) ? data.slice(0, 5) : [];
  }
} catch {
  matches = [];
}
---

<Layout>
  <main class="min-h-screen pb-20 md:pb-8">
    <div class="max-w-3xl mx-auto px-4 py-5 sm:py-6 md:py-8">
      <div class="section-header mb-8">
        <span class="section-eyebrow">Tonight on campus</span>
        <h1 id="kineticTitle" class="kinetic-text" style="text-shadow: 6px 6px 0px #FF3E00;">Discover Events</h1>
        <p class="section-subtitle">Find and RSVP to campus events that match your interests.</p>
      </div>

      <div class="mb-8 sticky top-0 bg-gradient-to-b from-nc-bg-root via-nc-bg-root to-nc-bg-root/0 backdrop-blur-sm z-10 pb-4 pt-1 space-y-3">
        <div class="overflow-x-auto scrollbar-thin -mx-1 px-1">
          <div class="flex gap-2 min-w-max" id="plannerStrip">
            {plannerPills.map((pill, i) => (
              <button
                type="button"
                class={`chip text-xs font-bold uppercase tracking-wider transition-all duration-200 flex-shrink-0 min-h-9 px-5 ${
                  i === 0 ? 'active' : ''
                }`}
                data-planner={pill}
              >
                {pill}
              </button>
            ))}
          </div>
        </div>

        <div class="overflow-x-auto scrollbar-thin">
          <div class="flex gap-2 min-w-max" id="feedFilterBar">
            {feedFilters.map((filter) => (
              <button
                type="button"
                class={`text-xs font-semibold uppercase tracking-wide transition-all duration-200 flex-shrink-0 rounded-full px-3 py-1.5 border ${
                  filter === 'All'
                    ? 'bg-nc-accent-primary/15 text-nc-accent-primary border-nc-accent-primary/40'
                    : 'text-nc-text-subtle border-nc-border-subtle hover:text-nc-text-primary hover:border-nc-text-subtle'
                }`}
                data-filter={filter}
              >
                {filter}
              </button>
            ))}
          </div>
        </div>
      </div>

      <div class="mb-4 flex flex-col gap-2 text-sm text-nc-text-muted sm:flex-row sm:items-center sm:justify-between">
        <p id="feedSummaryLabel">All campus activities</p>
        <p id="feedResultCount">{posts.length} {posts.length === 1 ? 'result' : 'results'}</p>
      </div>

      <div class="mb-6">
        <CreatePostForm client:load />
      </div>

      <div
        id="filteredFeedEmptyState"
        class="card text-center py-12 px-6 hidden mb-6"
        data-default-message="Try a different planner or category."
      >
        <svg class="w-12 h-12 mx-auto text-nc-text-subtle mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
        <p class="text-nc-text-primary font-semibold text-lg mb-1">No events match these filters</p>
        <p class="mt-2 text-sm text-nc-text-muted mb-0" id="filteredFeedEmptyMessage">Try a different planner or category.</p>
      </div>

      <div class="columns-1 md:columns-2 gap-6 stagger-container" id="postsContainer">
        {
          posts.length > 0 ? (
            posts.map((post, index) => (
              <div
                class="mb-6 break-inside-avoid inline-block w-full align-top"
                data-feed-post
                data-post-category={post.category}
                data-post-filter-keys={getPostFilterKeys(post).join(' ')}
                data-post-date={post.date}
              >
                <PostCard post={post} />

                {index === 2 && matches.length > 0 && (
                  <div class="card p-5 relative overflow-hidden mt-6" id="peopleSuggestionCard" data-feed-accessory>
                    <button
                      type="button"
                      id="dismissPeopleCard"
                      class="absolute top-3 right-3 w-7 h-7 rounded-full flex items-center justify-center text-nc-text-subtle hover:text-nc-text-primary hover:bg-nc-bg-elevated transition-all"
                      aria-label="Dismiss"
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>

                    <h3 class="text-sm font-bold text-nc-text-primary font-display uppercase tracking-wider mb-4 flex items-center gap-2">
                      <svg class="w-4 h-4 text-nc-accent-secondary" fill="currentColor" viewBox="0 0 20 20"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/></svg>
                      Students You Might Know
                    </h3>

                    <div class="flex gap-3 sm:gap-4 overflow-x-auto pb-2 scrollbar-thin snap-x snap-mandatory">
                      {matches.map((match) => {
                        const userId = match.id ?? match._id ?? '';
                        const interestTags = match.sharedInterestTags ?? match.sharedInterests ?? [];

                        return (
                          <div class="flex flex-col items-center gap-2 min-w-[112px] sm:min-w-[100px] flex-shrink-0 text-center snap-start">
                            <div class="h-12 w-12 rounded-full bg-gradient-to-br from-nc-accent-primary to-nc-accent-secondary flex items-center justify-center text-sm font-bold text-white">
                              {(match.name?.[0] ?? '?').toUpperCase()}
                            </div>
                            <p class="font-semibold text-nc-text-primary text-xs tracking-wide mb-0 line-clamp-1">{match.name}</p>
                            <p class="text-[10px] text-nc-text-muted mb-0 line-clamp-1">{match.major ?? 'Undeclared'}</p>
                            {interestTags.length > 0 && (
                              <span class="text-[10px] text-nc-accent-secondary">{interestTags.length} shared</span>
                            )}
                            <ConnectButton client:load userId={userId} />
                          </div>
                        );
                      })}
                    </div>

                    <a href="/people" class="block text-center text-xs text-nc-accent-primary font-semibold mt-3 hover:text-nc-accent-secondary transition-colors">See all people →</a>
                  </div>
                )}
              </div>
            ))
          ) : (
            <div class="card text-center py-12 px-6">
              <svg class="w-12 h-12 mx-auto text-nc-text-subtle mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
              <p class="text-nc-text-primary font-semibold text-lg mb-1">No events yet</p>
              <p class="mt-2 text-sm text-nc-text-muted mb-0">
                {selectedCategory === 'All'
                  ? 'Join groups or update your interests to find events matching your vibe.'
                  : `There are no ${selectedCategory.toLowerCase()} posts right now.`}
              </p>
              <div class="mt-6 flex justify-center gap-3">
                <a href="/groups" class="btn-primary text-sm">Join Groups</a>
                <a href="/people" class="btn-secondary text-sm">Find People</a>
              </div>
            </div>
          )
        }

        {posts.length > 0 && posts.length < 3 && matches.length > 0 && (
          <div class="mb-6 break-inside-avoid inline-block w-full align-top" data-feed-accessory-wrapper>
            <div class="card p-5 relative overflow-hidden" id="peopleSuggestionCardAlt" data-feed-accessory>
            <button
              type="button"
              class="dismiss-people-btn absolute top-3 right-3 w-7 h-7 rounded-full flex items-center justify-center text-nc-text-subtle hover:text-nc-text-primary hover:bg-nc-bg-elevated transition-all"
              aria-label="Dismiss"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>

            <h3 class="text-sm font-bold text-nc-text-primary font-display uppercase tracking-wider mb-4 flex items-center gap-2">
              <svg class="w-4 h-4 text-nc-accent-secondary" fill="currentColor" viewBox="0 0 20 20"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/></svg>
              Students You Might Know
            </h3>

            <div class="flex gap-3 sm:gap-4 overflow-x-auto pb-2 scrollbar-thin snap-x snap-mandatory">
              {matches.map((match) => {
                const userId = match.id ?? match._id ?? '';
                const interestTags = match.sharedInterestTags ?? match.sharedInterests ?? [];

                return (
                  <div class="flex flex-col items-center gap-2 min-w-[112px] sm:min-w-[100px] flex-shrink-0 text-center snap-start">
                    <div class="h-12 w-12 rounded-full bg-gradient-to-br from-nc-accent-primary to-nc-accent-secondary flex items-center justify-center text-sm font-bold text-white">
                      {(match.name?.[0] ?? '?').toUpperCase()}
                    </div>
                    <p class="font-semibold text-nc-text-primary text-xs tracking-wide mb-0 line-clamp-1">{match.name}</p>
                    <p class="text-[10px] text-nc-text-muted mb-0 line-clamp-1">{match.major ?? 'Undeclared'}</p>
                    {interestTags.length > 0 && (
                      <span class="text-[10px] text-nc-accent-secondary">{interestTags.length} shared</span>
                    )}
                    <ConnectButton client:load userId={userId} />
                  </div>
                );
              })}
            </div>

            <a href="/people" class="block text-center text-xs text-nc-accent-primary font-semibold mt-3 hover:text-nc-accent-secondary transition-colors">See all people →</a>
          </div>
          </div>
        )}
      </div>
    </div>
  </main>
</Layout>

<script>
  const planner = document.getElementById('plannerStrip');
  const filterBar = document.getElementById('feedFilterBar');
  const feedPosts = Array.from(document.querySelectorAll('[data-feed-post]'));
  const feedAccessories = Array.from(document.querySelectorAll('[data-feed-accessory]'));
  const accessoryWrappers = Array.from(document.querySelectorAll('[data-feed-accessory-wrapper]'));
  const filteredEmptyState = document.getElementById('filteredFeedEmptyState');
  const filteredEmptyMessage = document.getElementById('filteredFeedEmptyMessage');
  const feedSummaryLabel = document.getElementById('feedSummaryLabel');
  const feedResultCount = document.getElementById('feedResultCount');
  let activePlanner = 'Tonight';
  let activeCategory = 'All';

  function isPlannerMatch(postDateValue, plannerValue) {
    const postDate = new Date(postDateValue);
    if (Number.isNaN(postDate.getTime())) {
      return plannerValue === 'This Week';
    }

    const now = new Date();
    const startOfToday = new Date(now.getFullYear(), now.getMonth(), now.getDate());
    const endOfToday = new Date(startOfToday);
    endOfToday.setDate(endOfToday.getDate() + 1);

    if (plannerValue === 'Tonight') {
      return postDate >= startOfToday && postDate < endOfToday;
    }

    if (plannerValue === 'Weekend') {
      const day = postDate.getDay();
      return day === 6 || day === 0;
    }

    if (plannerValue === 'This Week') {
      const endOfWeek = new Date(startOfToday);
      endOfWeek.setDate(endOfWeek.getDate() + (7 - endOfWeek.getDay()));
      endOfWeek.setHours(23, 59, 59, 999);
      return postDate >= startOfToday && postDate <= endOfWeek;
    }

    return true;
  }

  function applyFeedFilters() {
    let visibleCount = 0;

    feedPosts.forEach((card) => {
      const postDate = card.getAttribute('data-post-date') ?? '';
      const filterKeys = (card.getAttribute('data-post-filter-keys') ?? '').split(/\s+/).filter(Boolean);
      const plannerMatch = isPlannerMatch(postDate, activePlanner);
      const categoryMatch = activeCategory === 'All' || filterKeys.includes(activeCategory.toLowerCase());
      const isVisible = plannerMatch && categoryMatch;

      card.classList.toggle('hidden', !isVisible);

      if (isVisible) {
        visibleCount += 1;
      }
    });

    feedAccessories.forEach((item) => {
      item.classList.toggle('hidden', visibleCount === 0);
    });

    accessoryWrappers.forEach((item) => {
      item.classList.toggle('hidden', visibleCount === 0);
    });

    if (filteredEmptyState) {
      filteredEmptyState.classList.toggle('hidden', visibleCount > 0 || feedPosts.length === 0);
    }

    if (filteredEmptyMessage) {
      const categoryText = activeCategory === 'All' ? 'all categories' : activeCategory.toLowerCase();
      filteredEmptyMessage.textContent = `No ${categoryText} events match ${activePlanner.toLowerCase()}.`;
    }

    if (feedSummaryLabel) {
      const categoryText = activeCategory === 'All' ? 'all campus activities' : `${activeCategory} activities`;
      feedSummaryLabel.textContent = `${activePlanner}: ${categoryText}`;
    }

    if (feedResultCount) {
      feedResultCount.textContent = `${visibleCount} ${visibleCount === 1 ? 'result' : 'results'}`;
    }
  }

  if (planner) {
    planner.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button');
      if (!btn) return;
      planner.querySelectorAll('button').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activePlanner = btn.dataset.planner ?? 'Tonight';
      applyFeedFilters();
    });
  }

  if (filterBar) {
    filterBar.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button');
      if (!btn) return;

      filterBar.querySelectorAll('button').forEach((button) => {
        button.classList.remove('bg-nc-accent-primary/15', 'text-nc-accent-primary', 'border-nc-accent-primary/40');
        button.classList.add('text-nc-text-subtle', 'border-nc-border-subtle');
      });

      btn.classList.remove('text-nc-text-subtle', 'border-nc-border-subtle');
      btn.classList.add('bg-nc-accent-primary/15', 'text-nc-accent-primary', 'border-nc-accent-primary/40');

      activeCategory = btn.dataset.filter ?? 'All';
      applyFeedFilters();
    });
  }

  applyFeedFilters();

  window.addEventListener('informed:post-created', () => {
    window.location.reload();
  });

  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-comments-toggle]');
    if (!btn) return;
    const postId = (btn as HTMLElement).dataset.commentsToggle;
    document.getElementById(`comments-${postId}`)?.classList.toggle('hidden');
  });

  document.querySelectorAll('#dismissPeopleCard, .dismiss-people-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const card = btn.closest('.card');
      if (card instanceof HTMLElement) {
        card.style.transition = 'opacity 0.3s ease, max-height 0.4s ease, margin 0.4s ease, padding 0.4s ease';
        card.style.opacity = '0';
        card.style.maxHeight = card.scrollHeight + 'px';
        requestAnimationFrame(() => {
          card.style.maxHeight = '0';
          card.style.marginTop = '0';
          card.style.marginBottom = '0';
          card.style.padding = '0';
          card.style.overflow = 'hidden';
        });
        setTimeout(() => card.remove(), 500);
      }
    });
  });

  // Kinetic Typography: mouse-tracking 3D text-shadow
  const kineticTitle = document.getElementById('kineticTitle');
  if (kineticTitle) {
    let rafId: number;
    const maxOffset = 12;
    document.addEventListener('mousemove', (e) => {
      if (rafId) cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(() => {
        const rect = kineticTitle.getBoundingClientRect();
        const centerX = rect.left + rect.width / 2;
        const centerY = rect.top + rect.height / 2;

        // Calculate distance from center of the title
        const dx = (e.clientX - centerX) / window.innerWidth;
        const dy = (e.clientY - centerY) / window.innerHeight;

        // Invert: shadow moves opposite to cursor
        const shadowX = Math.round(-dx * maxOffset * 2);
        const shadowY = Math.round(-dy * maxOffset * 2);

        kineticTitle.style.textShadow = `${shadowX}px ${shadowY}px 0px #FF3E00`;
      });
    });
  }
</script>

<style>
  .kinetic-text {
    transition: text-shadow 80ms ease-out;
    cursor: crosshair;
  }
</style>
