---
import PostCard from '../components/PostCard.astro';
import ConnectButton from '../components/ConnectButton.svelte';
import Layout from '../layouts/Layout.astro';
import { buildServerApiUrl } from '../lib/api';

type Post = {
  id: string;
  title: string;
  body?: string;
  author: string;
  category: string;
  rsvpCount: number;
  date: string;
  location?: string;
};

type MatchUser = {
  id?: string;
  _id?: string;
  name: string;
  major?: string;
  sharedInterestTags?: string[];
  sharedInterests?: string[];
};

const request = Astro.request;
const feedFilters = ['All', 'Social', 'Academic', 'Sports', 'Faith', 'Arts'];
const selectedCategory = Astro.url.searchParams.get('category') ?? 'All';
const authCookieHeader = Astro.request.headers.get('cookie') ?? '';

if (!authCookieHeader.includes('better-auth.session_token')) {
  return Astro.redirect('/login');
}

let posts: Post[] = [];
let matches: MatchUser[] = [];

try {
  const postsUrl = new URL(buildServerApiUrl('/api/posts', Astro.url));

  if (selectedCategory !== 'All') {
    postsUrl.searchParams.set('category', selectedCategory);
  }

  const response = await fetch(postsUrl.toString(), {
    headers: {
      cookie: authCookieHeader,
    },
  });

  if (response.ok) {
    const data = await response.json();
    posts = Array.isArray(data) ? data : [];
  }
} catch {
  posts = [];
}

try {
  const response = await fetch(buildServerApiUrl('/api/users/matches', Astro.url), {
    headers: {
      cookie: request.headers.get('cookie') ?? '',
    },
  });

  if (response.ok) {
    const data = await response.json();
    matches = Array.isArray(data) ? data.slice(0, 5) : [];
  }
} catch {
  matches = [];
}
---

<Layout>
  <main class="min-h-screen bg-slate-900 pb-20 md:pb-8">
    <div class="max-w-6xl mx-auto px-4 py-6 md:py-8 grid grid-cols-1 lg:grid-cols-3 gap-6">
      {/* Feed Section */}
      <section class="lg:col-span-2">
        <h1 class="text-3xl font-bold mb-6">Feed</h1>

        <div class="mb-6 overflow-x-auto">
          <div class="flex min-w-max gap-2">
            {feedFilters.map((filter) => (
              <a
                href={filter === 'All' ? '/feed' : `/feed?category=${encodeURIComponent(filter)}`}
                class={`rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-wide transition ${
                  filter === selectedCategory
                    ? 'border-indigo-500 bg-indigo-500 text-white'
                    : 'border-slate-600 bg-slate-800 text-slate-300 hover:bg-slate-700'
                }`}
              >
                {filter}
              </a>
            ))}
          </div>
        </div>

        <div class="mb-4 flex items-center justify-between gap-4 text-sm text-slate-400">
          <p>{selectedCategory === 'All' ? 'All campus activities' : `${selectedCategory} activities`}</p>
          <p>{posts.length} {posts.length === 1 ? 'result' : 'results'}</p>
        </div>

        {
          posts.length > 0 ? (
            posts.map((post) => <PostCard post={post} />)
          ) : (
            <div class="card text-center py-12">
              <p class="text-slate-300 font-semibold">No activities found.</p>
              <p class="mt-2 text-sm text-slate-400">
                {selectedCategory === 'All'
                  ? 'Join groups or update your interests to personalize your feed.'
                  : `There are no ${selectedCategory.toLowerCase()} posts right now.`}
              </p>
              <div class="mt-5 flex justify-center gap-3">
                <a href="/groups" class="btn-primary">Join Groups</a>
                <a href="/people" class="btn-secondary">Find People</a>
              </div>
            </div>
          )
        }
      </section>

      {/* People Discovery Sidebar */}
      <aside class="lg:col-span-1" aria-label="Students You Might Know">
        <div class="card sticky top-24 max-h-[calc(100vh-6rem)] overflow-y-auto">
          <h2 class="text-xl font-bold mb-4">Students You Might Know</h2>

          {
            matches.length > 0 ? (
              matches.map((match, index) => {
                const userId = match.id ?? match._id ?? '';
                const interestTags = match.sharedInterestTags ?? match.sharedInterests ?? [];

                return (
                  <article class={`flex flex-col gap-2 pb-4 ${index > 0 ? 'pt-4 border-t border-slate-600' : ''}`}>
                    <p class="font-semibold text-slate-100">{match.name}</p>
                    <p class="text-sm text-slate-400">{match.major ?? 'Undeclared'}</p>

                    {interestTags.length > 0 ? (
                      <ul class="flex flex-wrap gap-2">
                        {interestTags.map((tag) => (
                          <li class="badge badge-social text-xs">{tag}</li>
                        ))}
                      </ul>
                    ) : (
                      <p class="text-xs text-slate-400 italic">No shared interests yet</p>
                    )}

                    <div class="mt-2">
                      <ConnectButton client:load userId={userId} />
                    </div>
                  </article>
                );
              })
            ) : (
              <div class="text-center py-8">
                <p class="text-sm text-slate-400">No suggestions right now.</p>
              </div>
            )
          }
        </div>
      </aside>
    </div>
  </main>
</Layout>
