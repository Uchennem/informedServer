---
import PostCard from '../components/PostCard.astro';
import ConnectButton from '../components/ConnectButton.svelte';
import Layout from '../layouts/Layout.astro';
import { buildServerApiUrl } from '../lib/api';

type Post = {
  id: string;
  title: string;
  author: string;
  category: string;
  rsvpCount: number;
  date: string;
};

type MatchUser = {
  id?: string;
  _id?: string;
  name: string;
  major?: string;
  sharedInterestTags?: string[];
  sharedInterests?: string[];
};

const baseUrl = import.meta.env.PUBLIC_API_BASE_URL;
const request = Astro.request;
const feedFilters = ['All', 'Social', 'Academic', 'Sports', 'Faith', 'Arts'];
const authCookieHeader = Astro.request.headers.get('cookie') ?? '';

if (!authCookieHeader.includes('better-auth.session_token')) {
  return Astro.redirect('/login');
}

let posts: Post[] = [];
let matches: MatchUser[] = [];

try {
  const response = await fetch(buildServerApiUrl('/api/posts', Astro.url), {
    headers: {
      cookie: authCookieHeader,
    },
  });

  if (response.ok) {
    const data = await response.json();
    posts = Array.isArray(data) ? data : [];
  }
} catch {
  posts = [];
}

try {
  if (!baseUrl) {
    throw new Error('Missing PUBLIC_API_BASE_URL');
  }

  const response = await fetch(import.meta.env.PUBLIC_API_BASE_URL + '/api/users/matches', {
    headers: {
      cookie: request.headers.get('cookie') ?? '',
    },
  });

  if (response.ok) {
    const data = await response.json();
    matches = Array.isArray(data) ? data.slice(0, 5) : [];
  }
} catch {
  matches = [];
}
---

<Layout>
  <main class="min-h-screen pb-20 md:pb-8">
    <div class="max-w-7xl mx-auto px-4 py-6 md:py-8 grid grid-cols-1 lg:grid-cols-3 gap-8">
      {/* Feed Section */}
      <section class="lg:col-span-2">
        {/* Header */}
        <div class="mb-8">
          <h1 class="text-5xl font-bold text-slate-100 font-display uppercase tracking-wider mb-2">Discover Events</h1>
          <p class="text-slate-400 text-lg">Find and RSVP to campus events that match your interests</p>
        </div>

        {/* Category Filter Chips */}
        <div class="mb-8 sticky top-0 bg-gradient-to-b from-nc-bg-root via-nc-bg-root to-nc-bg-root/50 backdrop-blur z-10 pb-4">
          <div class="overflow-x-auto scrollbar-thin">
            <div class="flex gap-2 min-w-max">
              {feedFilters.map((filter) => (
                <button
                  type="button"
                  class={`chip text-xs font-semibold uppercase tracking-wide transition-all duration-200 flex-shrink-0 ${
                    filter === 'All'
                      ? 'bg-nc-accent-primary text-white shadow-lg shadow-nc-accent-primary/40 scale-105'
                      : 'bg-slate-700/50 text-slate-300 hover:bg-slate-600/50 hover:border-slate-500'
                  }`}
                  data-filter={filter}
                >
                  {filter}
                </button>
              ))}
            </div>
          </div>
        </div>

        {/* Posts List */}
        <div class="space-y-4 stagger-container">
          {
            posts.length > 0 ? (
              posts.map((post) => <PostCard post={post} />)
            ) : (
              <div class="card text-center py-16 border-2 border-dashed border-slate-600">
                <svg class="w-12 h-12 mx-auto text-slate-500 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
                <p class="text-slate-300 font-semibold text-lg">No events yet</p>
                <p class="mt-2 text-sm text-slate-400">Join groups or update your interests to find events matching your vibe</p>
                <div class="mt-6 flex justify-center gap-3">
                  <a href="/groups" class="btn-primary text-sm">Join Groups</a>
                  <a href="/people" class="btn-secondary text-sm">Find People</a>
                </div>
              </div>
            )
          }
        </div>
      </section>

      {/* People Discovery Sidebar */}
      <aside class="lg:col-span-1" aria-label="Students You Might Know">
        <div class="sticky top-24">
          <h2 class="text-2xl font-bold text-slate-100 font-display uppercase tracking-wide mb-4">Connect</h2>
          
          <div class="card max-h-[calc(100vh-8rem)] overflow-y-auto">
            {
              matches.length > 0 ? (
                matches.map((match, index) => {
                  const userId = match.id ?? match._id ?? '';
                  const interestTags = match.sharedInterestTags ?? match.sharedInterests ?? [];

                  return (
                    <div class={`flex flex-col gap-3 pb-4 transition-all duration-200 hover:bg-slate-700/30 p-3 rounded-lg ${index > 0 ? 'pt-4 border-t border-slate-600' : ''}`}>
                      <div>
                        <p class="font-bold text-slate-100 text-sm uppercase tracking-wide">{match.name}</p>
                        <p class="text-xs text-slate-400">{match.major ?? 'Undeclared'}</p>
                      </div>

                      {interestTags.length > 0 ? (
                        <div class="flex flex-wrap gap-1">
                          {interestTags.slice(0, 2).map((tag) => (
                            <span class="chip text-xs bg-nc-accent-primary/20 text-nc-accent-primary">{tag}</span>
                          ))}
                          {interestTags.length > 2 && (
                            <span class="chip text-xs text-slate-400">+{interestTags.length - 2}</span>
                          )}
                        </div>
                      ) : null}

                      <div class="mt-1">
                        <ConnectButton client:load userId={userId} />
                      </div>
                    </div>
                  );
                })
              ) : (
                <div class="text-center py-8">
                  <svg class="w-8 h-8 mx-auto text-slate-600 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-2a6 6 0 0112 0v2zm0 0h6v-2a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                  </svg>
                  <p class="text-xs text-slate-400">No suggestions right now</p>
                  <p class="text-xs text-slate-500 mt-1">Update your profile to get better matches</p>
                </div>
              )
            }
          </div>
        </div>
      </aside>
    </div>
  </main>
</Layout>