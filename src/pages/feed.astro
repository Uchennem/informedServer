---
import PostCard from '../components/PostCard.astro';
import Layout from '../layouts/Layout.astro';
import { buildServerApiUrl } from '../lib/api';

type Post = {
  id: string;
  title: string;
  author: string;
  category: string;
  rsvpCount: number;
  date: string;
};

const authCookieHeader = Astro.request.headers.get('cookie') ?? '';

if (!authCookieHeader.includes('better-auth.session_token')) {
  return Astro.redirect('/login');
}

let posts: Post[] = [];

try {
  const response = await fetch(buildServerApiUrl('/api/posts', Astro.url), {
    headers: {
      cookie: authCookieHeader,
    },
  });

  if (response.ok) {
    const data = await response.json();
    posts = Array.isArray(data) ? data : [];
  }
} catch {
  posts = [];
}
---

<Layout>
  <main class="feed">
    <h1>Feed</h1>

    {
      posts.length > 0 ? (
        posts.map((post) => <PostCard post={post} />)
      ) : (
        <p>No posts available.</p>
      )
    }
  </main>
</Layout>

<style>
  .feed {
    max-width: 760px;
    margin: 2rem auto;
    padding: 0 1rem;
  }

  h1 {
    margin: 0 0 1rem;
  }
</style>