---
import PostCard from '../components/PostCard.astro';
import ConnectButton from '../components/ConnectButton.svelte';
import Layout from '../layouts/Layout.astro';

type Post = {
  title: string;
  author: string;
  category: string;
  rsvpCount: number;
  date: string;
};

type MatchUser = {
  id?: string;
  _id?: string;
  name: string;
  major?: string;
  sharedInterestTags?: string[];
  sharedInterests?: string[];
};

const baseUrl = import.meta.env.PUBLIC_API_BASE_URL;
const request = Astro.request;

let posts: Post[] = [];
let matches: MatchUser[] = [];

try {
  if (!baseUrl) {
    throw new Error('Missing PUBLIC_API_BASE_URL');
  }

  const response = await fetch(`${baseUrl}/posts`);

  if (response.ok) {
    const data = await response.json();
    posts = Array.isArray(data) ? data : [];
  }
} catch {
  posts = [];
}

try {
  if (!baseUrl) {
    throw new Error('Missing PUBLIC_API_BASE_URL');
  }

  const response = await fetch(import.meta.env.PUBLIC_API_BASE_URL + '/api/users/matches', {
    headers: {
      cookie: request.headers.get('cookie') ?? '',
    },
  });

  if (response.ok) {
    const data = await response.json();
    matches = Array.isArray(data) ? data.slice(0, 5) : [];
  }
} catch {
  matches = [];
}
---

<Layout>
  <main class="feed-layout">
    <section class="feed">
      <h1>Feed</h1>

      {
        posts.length > 0 ? (
          posts.map((post) => <PostCard post={post} />)
        ) : (
          <p>No posts available.</p>
        )
      }
    </section>

    <aside class="people-discovery" aria-label="Students You Might Know">
      <h2>Students You Might Know</h2>

      {
        matches.length > 0 ? (
          matches.map((match) => {
            const userId = match.id ?? match._id ?? '';
            const interestTags = match.sharedInterestTags ?? match.sharedInterests ?? [];

            return (
              <article class="match-card">
                <p class="name">{match.name}</p>
                <p class="major">{match.major ?? 'Undeclared'}</p>

                {interestTags.length > 0 ? (
                  <ul class="tags">
                    {interestTags.map((tag) => (
                      <li>{tag}</li>
                    ))}
                  </ul>
                ) : (
                  <p class="no-tags">No shared interests yet</p>
                )}

                <ConnectButton client:load userId={userId} />
              </article>
            );
          })
        ) : (
          <p>No suggestions right now.</p>
        )
      }
    </aside>
  </main>
</Layout>

<style>
  .feed-layout {
    max-width: 1080px;
    margin: 2rem auto;
    padding: 0 1rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 1.25rem;
  }

  .feed {
    min-width: 0;
  }

  .feed h1 {
    margin: 0 0 1rem;
  }

  .people-discovery {
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 1rem;
    height: fit-content;
  }

  .people-discovery h2 {
    margin: 0 0 0.75rem;
    font-size: 1rem;
  }

  .match-card {
    border-top: 1px solid #f3f4f6;
    padding-top: 0.75rem;
    margin-top: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .match-card:first-of-type {
    border-top: 0;
    padding-top: 0;
    margin-top: 0;
  }

  .name {
    margin: 0;
    font-weight: 600;
  }

  .major {
    margin: 0;
    color: #4b5563;
    font-size: 0.9rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tags li {
    font-size: 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 9999px;
    padding: 0.1rem 0.45rem;
    color: #374151;
  }

  .no-tags {
    margin: 0;
    font-size: 0.8rem;
    color: #6b7280;
  }

  @media (max-width: 960px) {
    .feed-layout {
      grid-template-columns: 1fr;
    }
  }
</style>