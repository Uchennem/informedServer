---
import Layout from '../layouts/Layout.astro';
import styles from './register.module.css';
import eyeIcon from 'bootstrap-icons/icons/eye.svg';
import eyeSlashIcon from 'bootstrap-icons/icons/eye-slash.svg';

// Check if user is already authenticated by looking for auth cookie
const authCookie = Astro.request.headers.get('cookie')?.includes('better-auth.session_token');

if (authCookie) {
  return Astro.redirect('/feed');
}

const eyeIconUrl = eyeIcon.src;
const eyeSlashIconUrl = eyeSlashIcon.src;
---

<Layout>
  <div class={styles.container}>
    <div class={styles.card}>
      <h1>Create Account</h1>
      <form id="registerForm" class={styles.form}>
        <div class={styles.formGroup}>
          <label for="email">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="student@university.edu"
            required
          />
          <span id="emailError" class={styles.error}></span>
        </div>

        <div class={styles.formGroup}>
          <label for="name">Full Name</label>
          <input
            type="text"
            id="name"
            name="name"
            placeholder="John Doe"
            required
          />
          <span id="nameError" class={styles.error}></span>
        </div>

        <div class={styles.formGroup}>
          <label for="major">Major</label>
          <input
            type="text"
            id="major"
            name="major"
            placeholder="Computer Science"
            required
          />
          <span id="majorError" class={styles.error}></span>
        </div>

        <div class={styles.formGroup}>
          <label for="year">Year</label>
          <select id="year" name="year" required>
            <option value="">Select Year</option>
            <option value="freshman">Freshman</option>
            <option value="sophomore">Sophomore</option>
            <option value="junior">Junior</option>
            <option value="senior">Senior</option>
            <option value="graduate">Graduate</option>
          </select>
          <span id="yearError" class={styles.error}></span>
        </div>

        <div class={styles.formGroup}>
          <label for="password">Password</label>
          <div class={styles.passwordInputWrapper}>
            <input
              type="password"
              id="password"
              name="password"
              placeholder="Enter a strong password"
              required
            />
            <button
              type="button"
              id="togglePassword"
              class={styles.passwordToggle}
              aria-label="Toggle password visibility"
              data-eye-icon={eyeIconUrl}
              data-eye-slash-icon={eyeSlashIconUrl}
            >
              <img 
                id="toggleIcon" 
                src={eyeIcon.src} 
                alt="Show password" 
                width="20" 
                height="20"
              />
            </button>
          </div>
          <span id="passwordError" class={styles.error}></span>
          <div class={styles.passwordRequirements}>
            <p id="requirement-length" class={styles.requirementItem}>
              <span class={styles.requirementIcon}>✗</span> At least 8 characters
            </p>
            <p id="requirement-uppercase" class={styles.requirementItem}>
              <span class={styles.requirementIcon}>✗</span> At least one uppercase letter
            </p>
            <p id="requirement-lowercase" class={styles.requirementItem}>
              <span class={styles.requirementIcon}>✗</span> At least one lowercase letter
            </p>
            <p id="requirement-number" class={styles.requirementItem}>
              <span class={styles.requirementIcon}>✗</span> At least one number
            </p>
            <p id="requirement-special" class={styles.requirementItem}>
              <span class={styles.requirementIcon}>✗</span> At least one special character (! @ # $ % ^ & *)
            </p>
          </div>
        </div>

        <button type="submit" id="submitBtn" class={styles.submitBtn}>
          <span id="submitText">Create Account</span>
        </button>

        <p class={styles.loginLink}>
          Already have an account? <a href="/login">Sign in</a>
        </p>
      </form>

      <div id="successMessage" class={styles.successMessage}></div>
      <div id="errorMessage" class={styles.errorMessage}></div>
    </div>
  </div>
</Layout>

<script src="../js/register.ts"></script>
