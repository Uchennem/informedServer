---
import '../styles/global.css';
import { buildServerApiUrl } from '../lib/api';

// Check if user is already authenticated by looking for auth cookie
const authCookie = Astro.request.headers.get('cookie')?.includes('better-auth.session_token');

if (authCookie) {
	try {
		const response = await fetch(buildServerApiUrl('/api/users/me', Astro.url), {
			headers: {
				cookie: Astro.request.headers.get('cookie') ?? '',
			},
		});

		if (response.ok) {
			const payload = await response.json();
			return Astro.redirect(payload?.needsOnboarding ? '/onboarding' : '/feed');
		}
	} catch {
		// Fallback to feed if onboarding status cannot be resolved.
	}

	return Astro.redirect('/feed');
}
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="theme-color" content="#111113" />
		<title>Create Account — Informed</title>
		<meta name="description" content="Join Informed and discover campus events, clubs, and connections." />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="preconnect" href="https://api.fontshare.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
		<link href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@500;600;700&display=swap" rel="stylesheet" />
		<link href="https://api.fontshare.com/v2/css?f[]=clash-grotesk@400,500,600,700&display=swap" rel="stylesheet" />
	</head>
	<body>
		<div class="min-h-screen flex items-center justify-center px-4 py-10 md:py-14">
			<div class="w-full max-w-6xl grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-8 items-stretch">
				<!-- Hero Panel -->
				<section class="hidden lg:flex card relative overflow-hidden p-10 flex-col justify-between min-h-[580px]">
					<!-- Atmospheric gradient blobs -->
					<div class="absolute inset-0 pointer-events-none overflow-hidden">
						<div class="absolute -top-20 -left-20 h-80 w-80 rounded-full bg-gradient-to-br from-nc-accent-secondary/35 to-transparent blur-3xl animate-signal-pulse"></div>
						<div class="absolute bottom-0 right-0 h-80 w-80 rounded-full bg-gradient-to-tl from-nc-accent-primary/40 to-transparent blur-3xl animate-signal-pulse" style="animation-delay: 1.5s;"></div>
						<div class="absolute top-1/3 right-1/4 h-40 w-40 rounded-full bg-nc-success/15 blur-3xl animate-signal-pulse" style="animation-delay: 2.5s;"></div>
					</div>

					<div class="relative z-10 animate-slide-up">
						<p class="text-xs uppercase tracking-[0.18em] text-nc-text-subtle mb-4 font-display">Get started</p>
						<h1 class="text-5xl xl:text-6xl font-display font-bold text-nc-text-primary leading-[1.05] mb-5">
							Build your<br/>
							<span class="bg-gradient-to-r from-nc-accent-secondary to-nc-accent-primary bg-clip-text text-transparent">campus network</span><br/>
							in minutes.
						</h1>
						<p class="text-base text-nc-text-muted max-w-md leading-relaxed">Set up your profile, pick your interests, and discover people, groups, and events built for students like you.</p>
					</div>

					<div class="relative z-10 flex gap-2 mt-8 animate-fade-in" style="animation-delay: 0.3s;">
						<span class="chip active text-xs">Step 1</span>
						<span class="chip text-xs">Interests</span>
						<span class="chip text-xs">Explore</span>
					</div>
				</section>

				<!-- Auth Card -->
				<section class="w-full max-w-md lg:max-w-none mx-auto animate-slide-up" style="animation-delay: 0.15s;">
					<div class="card p-8 sm:p-10">
						<div class="mb-8 text-center lg:text-left">
							<p class="text-xs uppercase tracking-[0.16em] text-nc-text-subtle mb-2 font-display">Create account</p>
							<h1 class="text-4xl font-display font-bold text-nc-text-primary mb-2">Join Informed</h1>
							<p class="text-nc-text-muted text-sm mb-0">Join your campus community today.</p>
						</div>

						<form id="registerForm" class="space-y-5">
							<div>
								<label for="email" class="block text-sm font-semibold text-nc-text-primary mb-2">Email Address</label>
								<input
									type="email"
									id="email"
									name="email"
									placeholder="student@university.edu"
									required
								/>
								<span id="emailError" class="block text-nc-destructive text-xs mt-1.5"></span>
							</div>

							<div>
								<label for="name" class="block text-sm font-semibold text-nc-text-primary mb-2">Full Name</label>
								<input
									type="text"
									id="name"
									name="name"
									placeholder="John Doe"
									required
								/>
								<span id="nameError" class="block text-nc-destructive text-xs mt-1.5"></span>
							</div>

							<div>
								<label for="major" class="block text-sm font-semibold text-nc-text-primary mb-2">Major</label>
								<input
									type="text"
									id="major"
									name="major"
									placeholder="Computer Science"
									required
								/>
								<span id="majorError" class="block text-nc-destructive text-xs mt-1.5"></span>
							</div>

							<div>
								<label for="year" class="block text-sm font-semibold text-nc-text-primary mb-2">Year</label>
								<select id="year" name="year" required>
									<option value="">Select Your Year</option>
									<option value="freshman">Freshman</option>
									<option value="sophomore">Sophomore</option>
									<option value="junior">Junior</option>
									<option value="senior">Senior</option>
									<option value="graduate">Graduate</option>
								</select>
								<span id="yearError" class="block text-nc-destructive text-xs mt-1.5"></span>
							</div>

							<div>
								<label for="password" class="block text-sm font-semibold text-nc-text-primary mb-2">Password</label>
								<div class="relative mb-3">
									<input
										type="password"
										id="password"
										name="password"
										placeholder="••••••••"
										class="pr-12"
										required
									/>
									<button
										type="button"
										id="togglePassword"
										class="absolute right-4 top-1/2 -translate-y-1/2 text-nc-text-muted hover:text-nc-accent-primary transition-colors p-0 bg-transparent border-none"
										aria-label="Toggle password visibility"
									>
										<svg id="eyeOpenIcon" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path d="M10 12.5a2.5 2.5 0 100-5 2.5 2.5 0 000 5z"/><path fill-rule="evenodd" d="M.664 10.59a1.651 1.651 0 010-1.186A10.005 10.005 0 0110 3c4.257 0 7.893 2.66 9.336 6.41.147.38.147.804 0 1.186A10.005 10.005 0 0110 17c-4.257 0-7.893-2.66-9.336-6.41zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/></svg>
										<svg id="eyeClosedIcon" class="h-5 w-5 hidden" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3.28 2.22a.75.75 0 00-1.06 1.06l14.5 14.5a.75.75 0 101.06-1.06l-1.745-1.745a10.029 10.029 0 003.3-4.38 1.651 1.651 0 000-1.186A10.004 10.004 0 009.999 3a9.956 9.956 0 00-4.744 1.194L3.28 2.22zM7.752 6.69l1.092 1.092a2.5 2.5 0 013.374 3.373l1.092 1.092a4 4 0 00-5.558-5.558z" clip-rule="evenodd"/><path d="M10.748 13.93l2.523 2.523a9.987 9.987 0 01-3.27.547c-4.258 0-7.894-2.66-9.337-6.41a1.651 1.651 0 010-1.186 10.007 10.007 0 012.839-4.02l2.086 2.086A4 4 0 0010.748 13.93z"/></svg>
									</button>
								</div>

								<div class="space-y-2 p-4 rounded-xl bg-nc-bg-elevated/60 border border-nc-border-subtle">
									<p id="requirement-length" class="text-xs text-nc-text-muted flex items-center gap-2 mb-0">
										<span id="req-length-icon" class="text-nc-destructive font-bold">✗</span> At least 8 characters
									</p>
									<p id="requirement-uppercase" class="text-xs text-nc-text-muted flex items-center gap-2 mb-0">
										<span id="req-uppercase-icon" class="text-nc-destructive font-bold">✗</span> One uppercase letter
									</p>
									<p id="requirement-lowercase" class="text-xs text-nc-text-muted flex items-center gap-2 mb-0">
										<span id="req-lowercase-icon" class="text-nc-destructive font-bold">✗</span> One lowercase letter
									</p>
									<p id="requirement-number" class="text-xs text-nc-text-muted flex items-center gap-2 mb-0">
										<span id="req-number-icon" class="text-nc-destructive font-bold">✗</span> One number
									</p>
									<p id="requirement-special" class="text-xs text-nc-text-muted flex items-center gap-2 mb-0">
										<span id="req-special-icon" class="text-nc-destructive font-bold">✗</span> One special character (! @ # $ % ^ & *)
									</p>
								</div>
								<span id="passwordError" class="block text-nc-destructive text-xs mt-1.5"></span>
							</div>

							<button type="submit" id="submitBtn" class="btn-primary w-full mt-4">
								<span id="submitText">Create Account</span>
							</button>
						</form>

						<div id="successMessage" class="mt-4 p-3 rounded-xl bg-nc-success/10 border border-nc-success/20 text-nc-success text-sm hidden"></div>
						<div id="errorMessage" class="mt-4 p-3 rounded-xl bg-nc-destructive/10 border border-nc-destructive/20 text-nc-destructive text-sm hidden"></div>

						<p class="text-center lg:text-left text-nc-text-muted text-sm mt-6 mb-0">
							Already have an account?
							<a href="/login" class="text-nc-accent-primary font-semibold hover:text-nc-accent-secondary transition-colors">Sign in</a>
						</p>
					</div>
				</section>
			</div>
		</div>

		<script src="../js/register.ts"></script>
		<script>
			// Password toggle
			const toggle = document.getElementById('togglePassword');
			const passInput = document.getElementById('password') as HTMLInputElement;
			const eyeOpen = document.getElementById('eyeOpenIcon');
			const eyeClosed = document.getElementById('eyeClosedIcon');
			if (toggle && passInput && eyeOpen && eyeClosed) {
				toggle.addEventListener('click', () => {
					const isPassword = passInput.type === 'password';
					passInput.type = isPassword ? 'text' : 'password';
					eyeOpen.classList.toggle('hidden', !isPassword);
					eyeClosed.classList.toggle('hidden', isPassword);
				});
			}
		</script>
	</body>
</html>
