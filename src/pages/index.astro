---
// Check if user is authenticated by looking for auth cookie
const authCookie = Astro.request.headers.get('cookie')?.includes('better-auth.session_token');

if (authCookie) {
  // If authenticated, redirect to feed
  return Astro.redirect('/feed');
} else {
  // If not authenticated, redirect to login
  return Astro.redirect('/login');
}
