---
import Layout from '../layouts/Layout.astro';
import ConnectButton from '../components/ConnectButton.svelte';

type MatchUser = {
  id?: string;
  _id?: string;
  name: string;
  major?: string;
  year?: string | number;
  sharedInterestTags?: string[];
  sharedInterests?: string[];
};

const baseUrl = import.meta.env.PUBLIC_API_BASE_URL;
const request = Astro.request;
const filterChips = ['Major', 'Interest', 'Year'];

let matches: MatchUser[] = [];

try {
  if (!baseUrl) {
    throw new Error('Missing PUBLIC_API_BASE_URL');
  }

  const response = await fetch(`${baseUrl}/api/users/matches`, {
    headers: {
      cookie: request.headers.get('cookie') ?? '',
    },
  });

  if (response.ok) {
    const data = await response.json();
    matches = Array.isArray(data) ? data : [];
  }
} catch {
  matches = [];
}
---

<Layout>
  <main class="min-h-screen bg-slate-900 pb-20 md:pb-8">
    <div class="mx-auto max-w-6xl px-4 py-6 md:py-8">
      <h1 class="mb-6 text-3xl font-bold text-slate-100">People Discovery</h1>

      <div class="mb-6 overflow-x-auto">
        <div class="flex min-w-max gap-2">
          {filterChips.map((chip) => (
            <button
              type="button"
              class="rounded-full border border-slate-600 bg-slate-800 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-slate-300 transition hover:bg-slate-700"
            >
              {chip}
            </button>
          ))}
        </div>
      </div>

      {matches.length > 0 ? (
        <section class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
          {matches.map((match) => {
            const userId = match.id ?? match._id ?? '';
            const interestTags = match.sharedInterestTags ?? match.sharedInterests ?? [];

            return (
              <article class="card">
                <div class="mb-4 flex items-start justify-between gap-3">
                  <div class="flex items-center gap-3">
                    <div class="avatar flex items-center justify-center bg-slate-700 text-xs font-bold text-slate-200">
                      {(match.name?.[0] ?? '?').toUpperCase()}
                    </div>
                    <div>
                      <p class="font-semibold text-slate-100">{match.name}</p>
                      <p class="text-sm text-slate-400">{match.major ?? 'Undeclared'}{match.year ? ` • ${match.year}` : ''}</p>
                    </div>
                  </div>
                  <ConnectButton client:load userId={userId} mode="connect" />
                </div>

                {interestTags.length > 0 ? (
                  <div class="flex flex-wrap gap-2">
                    {interestTags.slice(0, 3).map((tag) => (
                      <span class="badge badge-academic text-xs">{tag}</span>
                    ))}
                  </div>
                ) : (
                  <p class="text-xs text-slate-400">No shared interests yet.</p>
                )}
              </article>
            );
          })}
        </section>
      ) : (
        <section class="card py-12 text-center">
          <p class="font-semibold text-slate-200">No people suggestions yet.</p>
          <p class="mt-2 text-sm text-slate-400">Join groups and add interests to get better matches.</p>
          <div class="mt-5">
            <a href="/groups" class="btn-primary">Explore Groups</a>
          </div>
        </section>
      )}
    </div>
  </main>
</Layout>