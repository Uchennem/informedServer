---
import Layout from '../layouts/Layout.astro';
import ConnectButton from '../components/ConnectButton.svelte';
import { buildServerApiUrl } from '../lib/api';

type MatchUser = {
  id?: string;
  _id?: string;
  name: string;
  major?: string;
  year?: string | number;
  sharedInterestTags?: string[];
  sharedInterests?: string[];
  isRequested?: boolean;
};

const request = Astro.request;
const authCookieHeader = request.headers.get('cookie') ?? '';

if (!authCookieHeader.includes('better-auth.session_token')) {
  return Astro.redirect('/login');
}

let matches: MatchUser[] = [];
const searchQuery = Astro.url.searchParams.get('q')?.trim() ?? '';
const endpoint = searchQuery.length >= 2
  ? buildServerApiUrl(`/api/users/search?q=${encodeURIComponent(searchQuery)}`, Astro.url)
  : buildServerApiUrl('/api/users/matches', Astro.url);

try {
  const response = await fetch(endpoint, {
    headers: {
      cookie: authCookieHeader,
    },
  });

  if (response.ok) {
    const data = await response.json();
    matches = Array.isArray(data) ? data : [];
  }
} catch {
  matches = [];
}
---

<Layout>
  <main class="min-h-screen pb-20 md:pb-8">
    <div class="mx-auto max-w-7xl px-4 py-5 sm:py-6 md:py-8">
      {/* Header */}
      <div class="section-header mb-6">
        <span class="section-eyebrow">Campus connections</span>
        <h1>Find Your People</h1>
        <p class="section-subtitle">Discover fellow students and build your community.</p>
      </div>

      {/* Search Bar */}
      <div class="mb-8 max-w-lg">
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-nc-text-subtle pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <input
            type="search"
            placeholder="Search by name or major..."
            class="w-full pl-10 pr-4 py-2.5 text-sm rounded-xl"
            id="peopleSearch"
            value={searchQuery}
          />
        </div>
        <p id="peopleSearchStatus" class="text-xs text-nc-text-subtle mt-2 hidden"></p>
      </div>

      {/* People Grid */}
      {matches.length > 0 ? (
        <section class="grid grid-cols-1 gap-4 sm:gap-5 md:grid-cols-2 lg:grid-cols-3 stagger-container">
          {matches.map((match) => {
            const userId = match.id ?? match._id ?? '';
            const interestTags = match.sharedInterestTags ?? match.sharedInterests ?? [];
            const sharedInterestsCount = interestTags.length;

            return (
              <article class="card group stagger-item relative overflow-hidden transition-all duration-300 hover:-translate-y-1 p-5 js-person-card" data-name={String(match.name ?? '').toLowerCase()} data-major={String(match.major ?? '').toLowerCase()}>
                {/* Accent bar */}
                <div class="absolute top-0 left-0 right-0 h-[3px] bg-nc-accent-primary"></div>

                <div class="flex items-start gap-3 mb-3">
                  <div class="w-11 h-11 rounded-full bg-gradient-to-br from-nc-accent-primary to-nc-accent-secondary flex items-center justify-center text-sm font-bold text-white flex-shrink-0">
                    {(match.name?.[0] ?? '?').toUpperCase()}
                  </div>
                  <div class="min-w-0">
                    <p class="font-bold text-nc-text-primary tracking-wide text-sm mb-0">{match.name}</p>
                    <p class="text-xs text-nc-text-muted mb-0">
                      {match.major ?? 'Undeclared'}
                      {match.year ? ` · ${match.year}` : ''}
                    </p>
                  </div>
                </div>

                {sharedInterestsCount > 0 && (
                  <p class="text-xs text-nc-accent-primary font-medium mb-3">{sharedInterestsCount} shared interests</p>
                )}

                {/* Interest tags */}
                {interestTags.length > 0 ? (
                  <div class="flex flex-wrap gap-1.5 mb-4">
                    {interestTags.slice(0, 3).map((tag) => (
                      <span class="text-[10px] font-medium rounded-full px-2 py-0.5 bg-nc-accent-primary/10 text-nc-accent-primary">
                        {tag}
                      </span>
                    ))}
                    {interestTags.length > 3 && (
                      <span class="text-[10px] text-nc-text-subtle">
                        +{interestTags.length - 3}
                      </span>
                    )}
                  </div>
                ) : (
                  <p class="text-xs text-nc-text-subtle mb-4 italic">No shared interests yet</p>
                )}

                {/* Connect Button */}
                <div class="pt-3 border-t border-nc-border-subtle/50">
                  <ConnectButton client:load userId={userId} mode="connect" initialRequested={Boolean(match.isRequested)} />
                </div>
              </article>
            );
          })}
        </section>
      ) : (
        <section class="max-w-md mx-auto text-center py-12">
          <svg class="w-10 h-10 mx-auto text-nc-text-subtle mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-2a6 6 0 0112 0v2zm0 0h6v-2a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
          <p class="font-semibold text-nc-text-primary mb-1">No matches yet</p>
          <p class="text-sm text-nc-text-muted mb-4">Try joining a group first — we'll find people with similar interests.</p>
          <a href="/groups" class="btn-secondary text-sm">Explore Groups</a>
        </section>
      )}
    </div>
  </main>
</Layout>

<script>
  const searchInput = document.getElementById('peopleSearch') as HTMLInputElement | null;
  const statusLine = document.getElementById('peopleSearchStatus') as HTMLElement | null;
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.js-person-card'));
  const queryParam = new URLSearchParams(window.location.search).get('q')?.trim() ?? '';

  if (searchInput && cards.length > 0) {
    let searchTimer: number | undefined;

    const setStatus = (message = '') => {
      if (!statusLine) return;
      statusLine.textContent = message;
      statusLine.classList.toggle('hidden', !message);
    };

    const applyLocalFilter = (value: string): number => {
      const query = value.trim().toLowerCase();

      if (!query) {
        cards.forEach((card) => {
          card.style.display = '';
        });
        setStatus('');
        return cards.length;
      }

      let visibleCount = 0;
      cards.forEach((card) => {
        const name = card.getAttribute('data-name') || '';
        const major = card.getAttribute('data-major') || '';
        const matches = name.includes(query) || major.includes(query);
        card.style.display = matches ? '' : 'none';
        if (matches) {
          visibleCount += 1;
        }
      });

      if (visibleCount === 0 && query.length >= 2) {
        setStatus('Searching all students...');
      } else if (visibleCount === 0) {
        setStatus('No local matches yet. Type at least 2 characters to search all students.');
      } else {
        setStatus('');
      }

      return visibleCount;
    };

    const runSearch = (value: string): void => {
      const query = value.trim();
      const visibleCount = applyLocalFilter(query);

      window.clearTimeout(searchTimer);
      searchTimer = window.setTimeout(() => {
        if (!query && queryParam) {
          window.location.href = '/people';
          return;
        }

        if (query.length >= 2 && visibleCount === 0 && query !== queryParam) {
          window.location.href = `/people?q=${encodeURIComponent(query)}`;
        }
      }, 300);
    };

    searchInput.addEventListener('input', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement)) {
        return;
      }

      runSearch(target.value);
    });

    searchInput.addEventListener('keydown', (event) => {
      if (event.key !== 'Enter') {
        return;
      }

      event.preventDefault();
      const query = searchInput.value.trim();

      if (query.length >= 2 && query !== queryParam) {
        window.location.href = `/people?q=${encodeURIComponent(query)}`;
      }
    });

    runSearch(searchInput.value);
  }
</script>
