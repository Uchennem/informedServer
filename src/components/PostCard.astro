---
import RSVPButton from './RSVPButton.svelte';

type Post = {
  title: string;
  author: string;
  category: string;
  rsvpCount: number;
  date: string;
};

type Props = {
  post: Post;
};

const { post } = Astro.props;

// Category badge class mapping  
const categoryClasses: Record<string, string> = {
  'Academic': 'bg-blue-500/20 text-blue-300',
  'Social': 'bg-pink-500/20 text-pink-300',
  'Sports': 'bg-green-500/20 text-green-300',
  'Faith': 'bg-purple-500/20 text-purple-300',
  'Arts': 'bg-orange-500/20 text-orange-300',
};

const badgeClass = categoryClasses[post.category] || categoryClasses['Academic'];
---

<article class="card group relative overflow-hidden transition-all duration-300 hover:shadow-lg hover:shadow-nc-accent-primary/30 hover:-translate-y-1 stagger-item">
  {/* Category color bar */}
  <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-nc-accent-primary via-nc-accent-secondary to-transparent"></div>

  <header class="mb-3">
    <h2 class="text-xl font-bold text-slate-100 group-hover:text-nc-accent-primary transition-colors font-display uppercase tracking-wide">{post.title}</h2>
  </header>

  <div class="mb-4 flex items-center justify-between gap-3">
    <span class="text-sm font-semibold text-slate-400">{post.author}</span>
    <span class={`chip text-xs font-semibold border border-slate-600 ${badgeClass}`}>
      {post.category}
    </span>
  </div>

  <time datetime={post.date} class="block text-xs text-slate-500 mb-4">
    {new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
  </time>

  <div class="flex items-center justify-between gap-4 pt-4 border-t border-slate-700/50">
    <div class="flex items-center gap-2">
      <svg class="w-4 h-4 text-nc-accent-secondary" fill="currentColor" viewBox="0 0 20 20">
        <path d="M2 6a2 2 0 012-2h12a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V6zM4 9a1 1 0 100 2h8a1 1 0 100-2H4z"/>
      </svg>
      <span class="font-semibold text-sm text-slate-300">{post.rsvpCount}</span>
    </div>
    <RSVPButton client:load initialCount={post.rsvpCount} />
  </div>
</article>