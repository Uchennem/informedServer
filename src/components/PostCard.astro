---
import RSVPButton from './RSVPButton.svelte';

type Post = {
  title: string;
  author: string;
  category: string;
  rsvpCount: number;
  date: string;
};

type Props = {
  post: Post;
};

const { post } = Astro.props;
---

<article class="card mb-4">
  <header>
    <h2 class="text-lg font-bold mb-2">{post.title}</h2>
  </header>

  <p class="text-slate-400 text-sm mb-4 flex gap-2">
    <span class="font-medium">{post.author}</span>
    <span>•</span>
    <span class="badge badge-social text-xs">{post.category}</span>
    <span>•</span>
    <time datetime={post.date}>{new Date(post.date).toLocaleDateString()}</time>
  </p>

  <div class="flex justify-between items-center gap-4">
    <p class="text-slate-400 font-semibold text-sm">RSVPs: {post.rsvpCount}</p>
    <RSVPButton client:load initialCount={post.rsvpCount} />
  </div>
</article>