---
import RSVPButton from './RSVPButton.svelte';

type Post = {
  title: string;
  author: string;
  category: string;
  rsvpCount: number;
  date: string;
};

type Props = {
  post: Post;
};

const { post } = Astro.props;
---

<article class="post-card">
  <header>
    <h2>{post.title}</h2>
  </header>

  <p class="meta">
    <span>{post.author}</span>
    <span>•</span>
    <span>{post.category}</span>
    <span>•</span>
    <time datetime={post.date}>{new Date(post.date).toLocaleDateString()}</time>
  </p>

  <div class="actions">
    <p class="count">RSVPs: {post.rsvpCount}</p>
    <RSVPButton client:load initialCount={post.rsvpCount} />
  </div>
</article>

<style>
  .post-card {
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 1rem;
    margin-bottom: 0.75rem;
  }

  .post-card h2 {
    margin: 0 0 0.5rem;
    font-size: 1.15rem;
  }

  .meta {
    display: flex;
    gap: 0.35rem;
    align-items: center;
    color: #4b5563;
    font-size: 0.9rem;
    margin: 0 0 0.8rem;
  }

  .actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .count {
    margin: 0;
    font-weight: 600;
  }
</style>