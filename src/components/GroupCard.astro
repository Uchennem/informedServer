---
type Group = {
  id: string;
  name: string;
  description?: string;
  category?: string;
  memberCount?: number;
  isMember?: boolean;
};

type Props = {
  group: Group;
};

const { group } = Astro.props;

// Category color palette
const categoryGradients: Record<string, string> = {
  'Academic': 'from-[#60A5FA] to-[#3d7de6]',
  'Social': 'from-pink-500 to-rose-400',
  'Sports': 'from-[#34D399] to-emerald-400',
  'Faith': 'from-[#6C63FF] to-violet-400',
  'Arts': 'from-[#FBBF24] to-amber-400',
  'General': 'from-nc-text-subtle to-nc-accent-primary',
};

const gradient = categoryGradients[group.category || 'General'] || categoryGradients['General'];
---

<article class="card group overflow-hidden flex flex-col transition-all duration-300 hover:-translate-y-1">
  {/* Colored Header Band */}
  <div class={`h-16 bg-gradient-to-r ${gradient} opacity-90 group-hover:opacity-100 transition-opacity flex items-center px-4 sm:px-6 relative overflow-hidden`}>
    <div class="absolute inset-0 opacity-20 mix-blend-overlay">
      <svg class="w-full h-full" viewBox="0 0 100 100">
        <circle cx="20" cy="20" r="15" fill="white" opacity="0.1"/>
        <circle cx="80" cy="80" r="20" fill="white" opacity="0.05"/>
        <circle cx="60" cy="30" r="8" fill="white" opacity="0.08"/>
      </svg>
    </div>
    <h2 class="text-lg font-bold text-white font-display tracking-wide relative z-10 mb-0 truncate">{group.name}</h2>
  </div>

  {/* Content */}
  <div class="flex-1 flex flex-col p-4 sm:p-6">
    {group.description ? (
      <p class="text-nc-text-muted text-sm mb-4 line-clamp-2">{group.description}</p>
    ) : null}

    <div class="flex items-center gap-2 mb-4 flex-wrap">
      {group.isMember && (
        <span class="chip text-xs bg-nc-success/15 text-nc-success border border-nc-success/30 font-semibold min-h-7 px-3">
          ✓ Joined
        </span>
      )}
      {group.category && (
        <span class="chip text-xs bg-nc-accent-primary/20 text-nc-accent-primary font-semibold min-h-7 px-3">
          {group.category}
        </span>
      )}
      <span class="text-xs text-nc-text-muted flex items-center gap-1">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
          <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/>
        </svg>
        {group.memberCount ?? 0} members
      </span>
    </div>

    <div class="mt-auto pt-4 border-t border-nc-border-subtle/50">
      <slot />
    </div>
  </div>
</article>
