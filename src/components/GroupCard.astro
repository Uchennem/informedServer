---
type Group = {
  id: string;
  name: string;
  description?: string;
  category?: string;
  memberCount?: number;
};

type Props = {
  group: Group;
};

const { group } = Astro.props;
---

<article class="card flex flex-col mb-0">
  <div class="flex-1">
    <h2 class="text-lg font-bold mb-2">{group.name}</h2>
    {group.description ? <p class="text-slate-300 text-sm mb-3">{group.description}</p> : null}

    <p class="text-slate-400 text-sm flex gap-2">
      <span class="badge badge-social text-xs">{group.category ?? 'General'}</span>
      <span>•</span>
      <span>{group.memberCount ?? 0} members</span>
    </p>
  </div>

  <div class="mt-4 flex justify-end">
    <slot />
  </div>
</article>