---
type Props = {
  variant?: 'event' | 'group' | 'person';
};

const { variant = 'event' } = Astro.props;

const hazardColors: Record<string, string> = {
  event: 'repeating-linear-gradient(45deg, #000, #000 10px, var(--nc-accent-primary) 10px, var(--nc-accent-primary) 20px)',
  group: 'repeating-linear-gradient(45deg, #000, #000 10px, var(--nc-accent-secondary) 10px, var(--nc-accent-secondary) 20px)',
  person: 'repeating-linear-gradient(45deg, #000, #000 10px, var(--nc-text-primary) 10px, var(--nc-text-primary) 20px)',
};

const hazardCss = hazardColors[variant] ?? hazardColors.event;
---

<div class="card p-6 stagger-item overflow-hidden relative min-h-[220px] border-[2px] border-nc-border-subtle shadow-[4px_4px_0px_0px_var(--nc-border-subtle)] flex items-center justify-center">
  <div class="absolute inset-0 opacity-40 hazard-bg pointer-events-none" style={`background: ${hazardCss};`}></div>
  <div class="z-10 bg-[#000] border-2 border-white px-6 py-2 font-display font-black uppercase text-2xl tracking-widest text-[#FFF] shadow-[3px_3px_0px_0px_#FFF]">
    LOADING
  </div>
</div>

<style>
  @keyframes hazardScroll {
    0% { background-position: 0px 0px; }
    100% { background-position: 28.28px 28.28px; }
  }

  .hazard-bg {
    animation: hazardScroll 1s linear infinite;
    background-size: 200% 200%;
  }
</style>
