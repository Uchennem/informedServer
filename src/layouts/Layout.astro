---
import '../styles/global.css';

const pathname = Astro.url.pathname;

const navItems = [
	{ href: '/feed', label: 'Feed', icon: '📰' },
	{ href: '/groups', label: 'Groups', icon: '👥' },
	{ href: '/people', label: 'People', icon: '🌟' },
	{ href: '/profile/me', label: 'Profile', icon: '🙍' },
];

const isActive = (href: string): boolean => {
	if (href === '/profile/me') {
		return pathname.startsWith('/profile');
	}
	return pathname === href || pathname.startsWith(`${href}/`);
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Informed</title>
	</head>
	<body>
		<div class="min-h-screen bg-slate-900 text-slate-200">
			<aside class="hidden md:fixed md:inset-y-0 md:left-0 md:flex md:w-64 md:flex-col md:border-r md:border-slate-700 md:bg-slate-800/80 md:backdrop-blur">
				<div class="px-5 py-6">
					<a href="/" class="text-2xl font-extrabold tracking-tight text-indigo-400">Informed</a>
					<p class="mt-1 text-sm text-slate-400">Built for students</p>
				</div>
				<nav class="px-3 pb-6">
					<ul class="space-y-2">
						{navItems.map((item) => (
							<li>
								<a
									href={item.href}
									class={`flex items-center gap-3 rounded-full px-4 py-2 text-sm font-semibold transition ${
										isActive(item.href)
											? 'bg-indigo-500 text-white'
											: 'text-slate-300 hover:bg-slate-700 hover:text-white'
									}`}
								>
									<span aria-hidden="true">{item.icon}</span>
									<span>{item.label}</span>
								</a>
							</li>
						))}
					</ul>
				</nav>
			</aside>

			<div class="md:pl-64">
				<header class="sticky top-0 z-20 border-b border-slate-700 bg-slate-900/95 backdrop-blur md:hidden">
					<div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
						<h1 class="text-base font-bold text-slate-100">Informed</h1>
						<div class="avatar flex items-center justify-center bg-slate-700 text-xs font-bold text-slate-200">ME</div>
					</div>
				</header>

				<slot />
			</div>

			<nav class="fixed inset-x-0 bottom-0 z-30 border-t border-slate-700 bg-slate-900/95 backdrop-blur md:hidden">
				<ul class="grid grid-cols-4">
					{navItems.map((item) => (
						<li>
							<a
								href={item.href}
								class={`flex flex-col items-center gap-1 px-2 py-2 text-[11px] font-semibold transition ${
									isActive(item.href) ? 'text-indigo-400' : 'text-slate-400 hover:text-slate-200'
								}`}
							>
								<span aria-hidden="true" class="text-base">{item.icon}</span>
								<span>{item.label}</span>
							</a>
						</li>
					))}
				</ul>
			</nav>
		</div>
	</body>
</html>
